generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(BUYER)

  cars      Car[]
  favorites Favorite[]

  createdAt DateTime @default(now())
}

enum Role {
  BUYER
  SELLER
  ADMIN
}

model Car {
  id          String  @id @default(uuid())
  title       String
  price       Float
  brand       String
  model       String
  year        Int
  description String?

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id])

  images CarImage[]

  createdAt  DateTime    @default(now())
  favorites  Favorite[]
  aiAnalysis AiAnalysis?
}

model CarImage {
  id  String @id @default(uuid())
  url String

  carId String
  car   Car    @relation(fields: [carId], references: [id])
}

model Favorite {
  id String @id @default(uuid())

  userId String
  carId  String

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])
}

model AiAnalysis {
  id             String @id @default(uuid())
  condition      String
  damageReport   String
  estimatedPrice Float

  carId String @unique
  car   Car    @relation(fields: [carId], references: [id])
}
